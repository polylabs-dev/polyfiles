/// Spec: specs/POLYFILES_CE_APP_GRAPH_SPEC.md
/// App Graph for PolyFiles — 15 ModuleNode definitions (12 core circuits + 3
/// graph circuits) composing scatter-distributed encrypted storage. Registers
/// intra-graph REQUIRES edges and cross-graph EDGE_BRIDGE_TO edges to QKit
/// collaboration, PolyDocs document_edit, and eStream scatter-CAS.

lex polyqlabs/qfiles

@target software
@codegen_targets ["wasm", "rust"]

import "core/deployment/module_stratum.fl" {
    ModuleNode, ModuleEdge, InterAppEdge, CsrStorage,
    CompilationReceipt, ResourceBudget8D, SemVer, CanaryTarget,
    ModuleType, AperturePartition, ModuleState, RolloutState,
    PersistencePolicy, OfflineCachePolicy, SLATier, EntitlementTier,
    EnforcementMode, BridgeScope,
    module_graph_add_module, module_graph_add_edge,
    module_graph_add_bridge_edge,
    EDGE_REQUIRES, EDGE_BRIDGE_TO,
}

// ── Constants ──────────────────────────────────────────────────────────────────

const POLYFILES_VERSION_MAJOR: u32 = 0
const POLYFILES_VERSION_MINOR: u32 = 1
const POLYFILES_VERSION_PATCH: u32 = 0
const POLYFILES_APP_LEX: string = "polyqlabs/qfiles"
const POLYFILES_VERSION_STR: string = "0.1.0"
const POLYFILES_MODULE_COUNT: u64 = 15

// ── Helpers ────────────────────────────────────────────────────────────────────

circuit qfiles_placeholder_receipt() -> CompilationReceipt
    lex polyqlabs/qfiles
    @status draft
    @precision D
{
    CompilationReceipt {
        source_hash: bytes(32, 0x00),
        compiler_version: SemVer {
            major: POLYFILES_VERSION_MAJOR,
            minor: POLYFILES_VERSION_MINOR,
            patch: POLYFILES_VERSION_PATCH,
            pre_release: "",
        },
        output_hash: bytes(32, 0x00),
        prime_device_id: None,
        compilation_timestamp: 0,
        reproducible_verified: false,
        receipt_signature: bytes(4627, 0x00),
    }
}

circuit make_qfiles_module(
    name: string,
    partition: u8,
    sla: u8,
    budget: ResourceBudget8D
) -> ModuleNode
    lex polyqlabs/qfiles
    @status draft
    @precision C
    observe metrics: [module_name, aperture_partition]
    meters [compute_cycles]
{
    ModuleNode {
        name: name,
        version_major: POLYFILES_VERSION_MAJOR,
        version_minor: POLYFILES_VERSION_MINOR,
        version_patch: POLYFILES_VERSION_PATCH,
        version_pre: "",
        module_type: ModuleType::SmartCircuit as u8,
        content_hash: bytes(32, 0x00),
        signature_chain: bytes(0),
        aperture_partition: partition,
        role_set: ["User", "Admin"],
        required_entitlement: EntitlementTier::Free as u8,
        classification_domains: [],
        max_classification_level: 0,
        compilation_receipt: qfiles_placeholder_receipt(),
        source_hash: bytes(32, 0x00),
        compiler_version_major: POLYFILES_VERSION_MAJOR,
        compiler_version_minor: POLYFILES_VERSION_MINOR,
        prime_device_id: bytes(0),
        reproducible_verified: false,
        resource_budget: budget,
        budget_enforcement_mode: EnforcementMode::Soft as u8,
        state: ModuleState::Active as u8,
        rollout_state: RolloutState::Canary as u8,
        canary_target: None,
        persistence: PersistencePolicy::Persistent as u8,
        offline_cache_policy: OfflineCachePolicy::CacheAndVerify as u8,
        max_staleness_seconds: 86400,
        sla_tier: sla,
        preferred_locality: "edge",
        created_at_ms: 0,
        updated_at_ms: 0,
    }
}

circuit make_requires_edge(
    source: string,
    target: string
) -> ModuleEdge
    lex polyqlabs/qfiles
    @status draft
    @precision D
{
    ModuleEdge {
        edge_type: EDGE_REQUIRES,
        source_module: source,
        source_version: POLYFILES_VERSION_STR,
        target_module: target,
        target_version_constraint: ">=" ++ POLYFILES_VERSION_STR,
        metadata: bytes(0),
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// Module Definitions — 15 ModuleNodes (12 core + 3 graphs)
// ═══════════════════════════════════════════════════════════════════════════════

// ── qfiles_chunk ── erasure-coded chunking over scatter-CAS ───────────────

circuit qfiles_chunk_module() -> ModuleNode
    lex polyqlabs/qfiles  @status draft  @precision B
    observe metrics: [module_init]  meters [compute_cycles]
{
    make_qfiles_module("qfiles_chunk", AperturePartition::Backend as u8,
        SLATier::Premium as u8, ResourceBudget8D {
            execution: 400000, hash_ops: 8000, bandwidth: 200000,
            storage: 500000, observe_events: 10000, proofs: 200,
            consensus: 50, memory: 134217728,
        })
}

