// ═══════════════════════════════════════════════════════════════════════════════
// Graph Registration
// ═══════════════════════════════════════════════════════════════════════════════

/// Register all 15 PolyFiles modules and their intra-graph REQUIRES dependency
/// edges into the provided CsrStorage graph.
circuit qfiles_app_graph_register(
    graph: CsrStorage
) -> CsrStorage
    lex polyqlabs/qfiles
    @status draft
    @precision B
    @attested true
    invariant "capacity" { graph.num_nodes + POLYFILES_MODULE_COUNT as u32 <= 4096 }
    observe metrics: [registered_module_count, registered_edge_count]
    meters [compute_cycles, memory_bytes]
{
    let (g, id_chunk)           = module_graph_add_module(graph, qfiles_chunk_module())
    let (g, id_classify)        = module_graph_add_module(g, qfiles_classify_module())
    let (g, id_dedup)           = module_graph_add_module(g, qfiles_dedup_module())
    let (g, id_doc_edit)        = module_graph_add_module(g, qfiles_document_edit_module())
    let (g, id_encrypt)         = module_graph_add_module(g, qfiles_encrypt_module())
    let (g, id_eslm_classify)   = module_graph_add_module(g, qfiles_eslm_classify_module())
    let (g, id_manifest)        = module_graph_add_module(g, qfiles_manifest_module())
    let (g, id_metering)        = module_graph_add_module(g, qfiles_metering_module())
    let (g, id_health)          = module_graph_add_module(g, qfiles_platform_health_module())
    let (g, id_rbac)            = module_graph_add_module(g, qfiles_rbac_module())
    let (g, id_share)           = module_graph_add_module(g, qfiles_share_module())
    let (g, id_storage_router)  = module_graph_add_module(g, qfiles_storage_router_module())
    let (g, id_file_graph)      = module_graph_add_module(g, file_graph_module())
    let (g, id_share_graph)     = module_graph_add_module(g, share_graph_module())
    let (g, id_version_dag)     = module_graph_add_module(g, version_dag_module())

    // ── Intra-graph REQUIRES edges ──────────────────────────────────────────
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_chunk", "qfiles_encrypt"), id_chunk, id_encrypt)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_dedup", "qfiles_chunk"), id_dedup, id_chunk)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_classify", "qfiles_manifest"), id_classify, id_manifest)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_eslm_classify", "qfiles_classify"), id_eslm_classify, id_classify)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_document_edit", "qfiles_manifest"), id_doc_edit, id_manifest)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_document_edit", "qfiles_encrypt"), id_doc_edit, id_encrypt)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_manifest", "file_graph"), id_manifest, id_file_graph)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_metering", "qfiles_manifest"), id_metering, id_manifest)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_platform_health", "qfiles_metering"), id_health, id_metering)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_rbac", "file_graph"), id_rbac, id_file_graph)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_share", "qfiles_rbac"), id_share, id_rbac)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_share", "share_graph"), id_share, id_share_graph)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_storage_router", "qfiles_chunk"), id_storage_router, id_chunk)
    let g = module_graph_add_edge(g, make_requires_edge("qfiles_storage_router", "qfiles_dedup"), id_storage_router, id_dedup)
    let g = module_graph_add_edge(g, make_requires_edge("version_dag", "qfiles_manifest"), id_version_dag, id_manifest)

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Cross-Graph Bridge Edges
// ═══════════════════════════════════════════════════════════════════════════════

/// Register EDGE_BRIDGE_TO edges linking PolyFiles to external graphs:
/// PolyDocs (document editing), QKit (collaboration), eStream scatter-CAS.
circuit qfiles_register_bridge_edges(
    graph: CsrStorage
) -> CsrStorage
    lex polyqlabs/qfiles
    @status draft
    @precision B
    @attested true
    observe metrics: [bridge_count]
    meters [compute_cycles]
{
    let doc_edit_id = 0xFFFFFFFF as u32
    let share_id = 0xFFFFFFFF as u32
    let chunk_id = 0xFFFFFFFF as u32
    let router_id = 0xFFFFFFFF as u32

    for i in 0..graph.num_nodes {
        let node_data = graph.node_data[i]
        let module = deserialize(node_data) as ModuleNode
        if module.name == "qfiles_document_edit" { doc_edit_id = i }
        if module.name == "qfiles_share" { share_id = i }
        if module.name == "qfiles_chunk" { chunk_id = i }
        if module.name == "qfiles_storage_router" { router_id = i }
    }

    let g = graph

    // qfiles_document_edit -> PolyDocs editor
    if doc_edit_id != 0xFFFFFFFF as u32 {
        let qdocs_bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYFILES_APP_LEX,
            source_module: "qfiles_document_edit",
            target_lex: "polyqlabs/qdocs",
            target_module: "qdocs_editor",
            bridge_scope: BridgeScope::Product as u8,
            shared_fields: ["document_ops", "crdt_state", "version_id"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, qdocs_bridge, doc_edit_id)
    }

    // qfiles_share -> QKit collaboration
    if share_id != 0xFFFFFFFF as u32 {
        let qkit_bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYFILES_APP_LEX,
            source_module: "qfiles_share",
            target_lex: "polyqlabs/qkit",
            target_module: "qkit_collaboration",
            bridge_scope: BridgeScope::Product as u8,
            shared_fields: ["share_token", "acl_policy", "invite_state"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, qkit_bridge, share_id)
    }

    // qfiles_chunk -> eStream scatter-CAS
    if chunk_id != 0xFFFFFFFF as u32 {
        let scatter_chunk_bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYFILES_APP_LEX,
            source_module: "qfiles_chunk",
            target_lex: "core/scatter_cas",
            target_module: "scatter_cas_core",
            bridge_scope: BridgeScope::Platform as u8,
            shared_fields: ["chunk_id", "erasure_params", "shard_map"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, scatter_chunk_bridge, chunk_id)
    }

    // qfiles_storage_router -> eStream scatter-CAS
    if router_id != 0xFFFFFFFF as u32 {
        let scatter_router_bridge = InterAppEdge {
            edge_type: EDGE_BRIDGE_TO,
            source_lex: POLYFILES_APP_LEX,
            source_module: "qfiles_storage_router",
            target_lex: "core/scatter_cas",
            target_module: "scatter_cas_core",
            bridge_scope: BridgeScope::Platform as u8,
            shared_fields: ["tier_policy", "routing_table", "replica_set"],
            redacted_fields: [],
            bilateral_confirmed: false,
        }
        g = module_graph_add_bridge_edge(g, scatter_router_bridge, router_id)
    }

    g
}

// ═══════════════════════════════════════════════════════════════════════════════
// Golden Tests
// ═══════════════════════════════════════════════════════════════════════════════

#[test]
circuit test_qfiles_app_graph_register()
    lex polyqlabs/qfiles
{
    let empty_graph = CsrStorage { num_nodes: 0, node_data: [], edge_data: [], bridge_data: [] }
    let g = qfiles_app_graph_register(empty_graph)
    assert g.num_nodes == 15, "expected 15 modules"
    assert len(g.edge_data) == 15, "expected 15 intra-graph edges"
}

#[test]
circuit test_qfiles_bridge_edges()
    lex polyqlabs/qfiles
{
    let empty_graph = CsrStorage { num_nodes: 0, node_data: [], edge_data: [], bridge_data: [] }
    let g = qfiles_app_graph_register(empty_graph)
    let g = qfiles_register_bridge_edges(g)
    assert len(g.bridge_data) == 4, "expected 4 bridge edges"
}

#[test]
circuit test_make_qfiles_module_defaults()
    lex polyqlabs/qfiles
{
    let m = make_qfiles_module("test_module", AperturePartition::Backend as u8,
        SLATier::Standard as u8, ResourceBudget8D {
            execution: 100, hash_ops: 10, bandwidth: 50,
            storage: 50, observe_events: 10, proofs: 1,
            consensus: 1, memory: 1024,
        })
    assert m.name == "test_module"
    assert m.version_major == 0
    assert m.version_minor == 1
    assert m.state == ModuleState::Active as u8
}
